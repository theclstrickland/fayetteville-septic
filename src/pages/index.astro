---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
---

<Base>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <h1 class="fade-up">
        {site.city} Septic Tank Pumping &amp; Repair
      </h1>
      <p class="hero-sub fade-up fade-up-d1">
        We provide septic tank pumping, cleaning, repair, and inspection in {site.city}, {site.state} and the surrounding counties. Call now for fast local service and a free estimate.
      </p>
      <div class="hero-phone fade-up fade-up-d2">
        <a href={`tel:${site.phoneTel}`}>{site.phone}</a>
      </div>
      <div class="hero-actions fade-up fade-up-d3">
        <a href={`tel:${site.phoneTel}`} class="btn-primary pulse">Call Now</a>
        <a href="#contact" class="btn-secondary-light">Request a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BAR ============ -->
  <div class="trust-bar">
    <div class="container">
      <div class="trust-items">
        {
          site.trustBadges.map((b) => (
            <div class="trust-item">
              <Icon name={b.icon} size={16} />
              {b.text}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ============ SERVICES ============ -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-label">What We Do</div>
      <h2 class="section-title">Septic Tank Services in {site.city}, {site.state}</h2>
      <p class="section-subtitle">
        {site.name} is your local team for septic tank pumping, cleaning, repair, emergency service,
        and certified inspections. Real local crews. Honest pricing. Fast response across the {
          site.city
        } metro.
      </p>
      <div class="services-grid">
        {
          site.services.map((s) => (
            <div class="service-card">
              <div class="service-icon"><Icon name={s.icon} size={28} /></div>
              <h3>{s.title}</h3>
              <p>{s.shortDesc}</p>
              <a href={s.linkHref} class="service-link">
                {s.linkText} →
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ PRICING DETAIL ============ -->
  <section class="detail alt" id="pricing">
    <div class="container">
      <div class="detail-content">
        <div class="section-label">Most Popular Service</div>
        <h2>Septic Tank Pumping in {site.city}</h2>
        <p>
          Routine pumping is the single most important service for keeping your system healthy. Skip
          too many and solids migrate into your drain field — turning a $400 pump into a $10,000
          drain field repair.
        </p>
        <p>
          Our local {site.city} crew dispatches same-day for most addresses, with flat-rate pricing confirmed
          before the truck leaves. {site.stateFull}'s {site.region} clay soils make a properly maintained
          tank matter even more than in sandier regions.
        </p>
        <a href={`tel:${site.phoneTel}`} class="btn-primary">Call for Same-Day Service</a>
      </div>
      <div class="detail-right">
        <img
          src="https://images.pexels.com/photos/6419128/pexels-photo-6419128.jpeg?auto=compress&cs=tinysrgb&w=600"
          alt={`Septic tank pumping service truck in ${site.city}, NC`}
          loading="lazy"
          width="600"
          height="400"
          class="detail-photo"
        />
        <div class="detail-visual">
        <h4 class="price-table-heading">{site.city} Area Pricing</h4>
        {
          site.pricing.map((p) => (
            <div class="detail-price-row">
              <span>{p.label}</span>
              <span>{p.value}</span>
            </div>
          ))
        }
        <p class="price-note">
          Prices confirmed on the phone before dispatch. No surprise charges. If we find something
          unexpected on-site, we stop and call you first.
        </p>
      </div>
      </div>
    </div>
  </section>

  <!-- ============ EMERGENCY CTA ============ -->
  <section class="emergency">
    <div class="container">
      <h2>Septic Emergency in {site.city}? Call Now.</h2>
      <p>Sewage backup, overflow, or tank failure? We answer 24/7 and dispatch within 90–120 minutes.</p>
      <a href={`tel:${site.phoneTel}`} class="btn-primary">Call {site.phone}</a>
    </div>
  </section>

  <!-- ============ LOCATIONS ============ -->
  <section class="locations" id="locations">
    <div class="container">
      <div class="section-label">Service Area</div>
      <h2 class="section-title">Septic Tank Service Near Me: {site.city} Metro</h2>
      <p class="section-subtitle">
        We provide local septic tank service across the {site.city} metro and surrounding counties.
      </p>
      <div class="locations-grid">
        {
          site.locations.map((l) => (
            <a href={`/${l.slug}/`} class="location-card">
              <span class="location-dot" />
              {l.name}
            </a>
          ))
        }
      </div>
      <p class="counties-served">
        <strong>Counties served:</strong>
        {site.counties}.
      </p>
    </div>
  </section>

  <!-- ============ WHY US ============ -->
  <section class="why-us">
    <div class="container">
      <div class="section-label">Why Choose Us</div>
      <h2 class="section-title">Why Choose {site.name}</h2>
      <div class="why-grid">
        {
          site.reasons.map((r) => (
            <div class="why-item">
              <div class="why-icon"><Icon name={r.icon} size={20} /></div>
              <div>
                <h4>{r.title}</h4>
                <p>{r.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="faq" id="faq">
    <div class="container">
      <div style="text-align:center;">
        <div class="section-label">Common Questions</div>
        <h2 class="section-title">Septic Service Questions, Answered</h2>
      </div>
      <div class="faq-grid">
        {
          site.faqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: site.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    })}
  />

  <!-- ============ BOTTOM CTA ============ -->
  <section class="bottom-cta" id="contact">
    <div class="container">
      <h2>Reliable Septic Service in {site.city}</h2>
      <p>Real local team. Honest pricing. Fast response. Free estimates.</p>
      <a href={`tel:${site.phoneTel}`} class="btn-primary" style="font-size:18px;padding:18px 36px;"
        >Call {site.phone}</a
      >
    </div>
  </section>
</Base>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    background: url('https://images.pexels.com/photos/8961065/pexels-photo-8961065.jpeg?auto=compress&cs=tinysrgb&w=1400') center/cover no-repeat;
    padding: 100px 0 110px;
    overflow: hidden;
    text-align: center;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(20, 35, 50, 0.88) 0%, rgba(20, 35, 50, 0.75) 100%);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 800;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
    color: #fff;
    max-width: 800px;
  }
  .hero-sub {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 28px;
    max-width: 620px;
    line-height: 1.7;
  }
  .hero-phone {
    margin-bottom: 24px;
  }
  .hero-phone a {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .hero-phone a:hover {
    text-decoration: underline;
  }
  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn-secondary-light {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: #fff;
    padding: 16px 28px;
    border-radius: var(--radius);
    font-size: 16px;
    font-weight: 600;
    font-family: var(--font-body);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }
  .btn-secondary-light:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ── Trust Bar ── */
  .trust-bar {
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: nowrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-light);
    white-space: nowrap;
  }
  .trust-icon {
    font-size: 16px;
    flex-shrink: 0;
  }

  /* ── Services ── */
  .services {
    padding: 80px 0;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }
  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: box-shadow 0.3s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .service-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .service-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .service-card:hover::after {
    opacity: 1;
  }
  .service-icon {
    width: 48px;
    height: 48px;
    background: var(--accent-light);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .service-card h3 {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .service-card p {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .service-link {
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
  }
  .service-link:hover {
    gap: 8px;
  }

  /* ── Detail / Pricing ── */
  .detail {
    padding: 80px 0;
  }
  .detail.alt {
    background: var(--bg-alt);
  }
  .detail .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }
  .detail-right {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .detail-photo {
    border-radius: var(--radius-lg);
    width: 100%;
    height: auto;
    object-fit: cover;
    box-shadow: var(--shadow-lg);
  }
  .detail-content h2 {
    font-size: clamp(26px, 2.8vw, 36px);
    font-weight: 800;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .detail-content p {
    font-size: 16px;
    color: var(--text-light);
    margin-bottom: 16px;
    line-height: 1.8;
  }
  .detail-visual {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    padding: 24px;
    box-shadow: var(--shadow);
  }
  .price-table-heading {
    font-family: var(--font-body);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-light);
    margin-bottom: 16px;
  }
  .detail-price-row {
    display: flex;
    justify-content: space-between;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }
  .detail-price-row:last-of-type {
    border-bottom: none;
  }
  .detail-price-row span:first-child {
    color: var(--text-light);
  }
  .detail-price-row span:last-child {
    font-weight: 700;
    color: var(--heading);
  }
  .price-note {
    font-size: 13px;
    color: var(--text-light);
    margin-top: 16px;
    line-height: 1.6;
  }

  /* ── Emergency ── */
  .emergency {
    background: var(--bg-dark);
    color: var(--text-inverse);
    padding: 60px 0;
    text-align: center;
  }
  .emergency h2 {
    color: #fff;
    font-size: clamp(26px, 3vw, 38px);
    margin-bottom: 12px;
  }
  .emergency p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 17px;
    margin-bottom: 28px;
  }
  .emergency .btn-primary {
    font-size: 18px;
    padding: 18px 36px;
  }

  /* ── Locations ── */
  .locations {
    padding: 80px 0;
  }
  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
    margin-top: 32px;
  }
  .location-card {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    font-weight: 500;
    font-size: 15px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .location-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .location-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .counties-served {
    font-size: 14px;
    color: var(--text-light);
    margin-top: 20px;
  }

  /* ── Why Us ── */
  .why-us {
    padding: 80px 0;
    background: var(--bg-alt);
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 40px;
  }
  .why-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .why-icon {
    width: 40px;
    height: 40px;
    background: var(--accent-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .why-item h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 4px;
  }
  .why-item p {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.6;
  }

  /* ── FAQ ── */
  .faq {
    padding: 80px 0;
  }
  .faq-grid {
    max-width: 780px;
    margin: 40px auto 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-item summary {
    padding: 20px 0;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--heading);
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    font-size: 22px;
    font-weight: 300;
    color: var(--accent);
    transition: transform 0.2s;
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-item p {
    padding: 0 0 20px;
    font-size: 15px;
    color: var(--text-light);
    line-height: 1.7;
  }

  /* ── Bottom CTA ── */
  .bottom-cta {
    padding: 80px 0;
    background: var(--bg-alt);
    text-align: center;
  }
  .bottom-cta h2 {
    font-size: clamp(28px, 3vw, 40px);
    margin-bottom: 12px;
  }
  .bottom-cta p {
    color: var(--text-light);
    font-size: 17px;
    margin-bottom: 28px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .detail .container {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 680px) {
    .hero {
      padding: 64px 0 72px;
    }
    .services-grid {
      grid-template-columns: 1fr;
    }
    .why-grid {
      grid-template-columns: 1fr;
    }
    .trust-items {
      flex-wrap: wrap;
      gap: 12px;
    }
    .trust-item {
      font-size: 12px;
    }
    .locations-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
