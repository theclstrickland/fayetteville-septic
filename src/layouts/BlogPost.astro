---
import Base from './Base.astro';
import { site } from '../data/site';
import { blogPosts } from '../data/blog';

interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
  slug: string;
}

const { title, description, date, readTime, slug } = Astro.props;
const otherPosts = blogPosts.filter((p) => p.slug !== slug).slice(0, 3);
const formattedDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${title} | ${site.name}`} description={description}>
  <article class="blog-post">
    <div class="container">
      <div class="blog-meta">
        <time datetime={date}>{formattedDate}</time>
        <span class="blog-meta-sep">|</span>
        <span>{readTime}</span>
      </div>

      <div class="blog-content">
        <slot />
      </div>

      <div class="blog-cta">
        <h3>Need Septic Service in {site.city}?</h3>
        <p>Local team. Flat-rate pricing. Same-day service available.</p>
        <a href={`tel:${site.phoneTel}`} class="btn-primary">Call {site.phone}</a>
      </div>

      {otherPosts.length > 0 && (
        <div class="blog-related">
          <h3>More from Our Blog</h3>
          <div class="blog-related-grid">
            {otherPosts.map((p) => (
              <a href={`/blog/${p.slug}/`} class="blog-related-card">
                <span class="blog-related-title">{p.title}</span>
                <span class="blog-related-desc">{p.description}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</Base>

<style>
  .blog-post {
    padding: 48px 0 80px;
  }
  .blog-post .container {
    max-width: 780px;
  }
  .blog-meta {
    font-size: 14px;
    color: var(--text-light);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .blog-meta-sep {
    opacity: 0.3;
  }

  /* Content styling */
  .blog-content :global(h1) {
    font-size: clamp(30px, 3.5vw, 44px);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    line-height: 1.15;
  }
  .blog-content :global(h2) {
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 700;
    margin: 40px 0 16px;
    letter-spacing: -0.01em;
  }
  .blog-content :global(h3) {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 700;
    margin: 32px 0 12px;
  }
  .blog-content :global(p) {
    font-size: 16.5px;
    line-height: 1.8;
    color: var(--text);
    margin-bottom: 16px;
  }
  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }
  .blog-content :global(li) {
    font-size: 16.5px;
    line-height: 1.7;
    margin-bottom: 8px;
    color: var(--text);
  }
  .blog-content :global(strong) {
    font-weight: 700;
    color: var(--heading);
  }
  .blog-content :global(a) {
    color: var(--accent);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-content :global(a:hover) {
    color: var(--accent-hover);
  }

  /* CTA */
  .blog-cta {
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
    padding: 32px;
    text-align: center;
    margin: 48px 0;
  }
  .blog-cta h3 {
    font-family: var(--font-display);
    font-size: 22px;
    margin-bottom: 8px;
  }
  .blog-cta p {
    color: var(--text-light);
    margin-bottom: 16px;
  }

  /* Related posts */
  .blog-related {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .blog-related h3 {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .blog-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }
  .blog-related-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .blog-related-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .blog-related-title {
    font-weight: 700;
    font-size: 15px;
    color: var(--heading);
    line-height: 1.3;
  }
  .blog-related-desc {
    font-size: 13px;
    color: var(--text-light);
    line-height: 1.5;
  }
</style>
